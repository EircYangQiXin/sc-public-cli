# =========================================================
# 环境变量样例 — .env.example
# =========================================================
# 使用方式：
#   1. 复制本文件为 .env
#   2. 修改为实际环境的值
#   3. docker-compose 会自动读取 .env 文件
#   4. 本地开发可通过 IDE Run Configuration 注入
#
# ⚠️ 以下默认值仅供本地开发演示，生产环境务必全部修改！
# =========================================================

# -------------------- Nacos --------------------
NACOS_ADDR=localhost:8848
NACOS_NAMESPACE=dev

# -------------------- MySQL --------------------
MYSQL_ADDR=localhost:3306
MYSQL_USER=root
MYSQL_PWD=root

# -------------------- Redis --------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=

# -------------------- RabbitMQ --------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PWD=guest

# -------------------- MinIO / OSS --------------------
MINIO_ADDR=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# -------------------- Sentinel --------------------
SENTINEL_ADDR=localhost:8858

# -------------------- Zipkin --------------------
ZIPKIN_BASE_URL=http://localhost:9411

# -------------------- Sleuth --------------------
SLEUTH_SAMPLER_PROBABILITY=0.1

# -------------------- XXL-JOB --------------------
XXLJOB_ADDR=localhost:8081

# -------------------- Grafana --------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
